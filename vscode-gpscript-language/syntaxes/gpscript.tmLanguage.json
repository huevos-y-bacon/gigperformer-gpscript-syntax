{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GPScript",
  "scopeName": "source.gpscript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#heredoc"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#sysex"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#notes"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#types"
    },
    {
      "include": "#callbacks"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.gpscript",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.gpscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "heredoc": {
      "name": "string.unquoted.heredoc.gpscript",
      "begin": "<<<",
      "end": ">>>"
    },
    "strings": {
      "name": "string.quoted.double.gpscript",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.gpscript",
          "match": "\\\\."
        }
      ]
    },
    "sysex": {
      "name": "constant.other.sysex.gpscript",
      "begin": "(?i:#\\s*F0\\b)",
      "end": "(?i:\\bF7\\b)"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.gpscript",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.gpscript",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "notes": {
      "name": "constant.numeric.note.gpscript",
      "match": "\\b[A-G](?:#|b)?-?\\d\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.gpscript",
      "match": "(?i:\\b(true|false)\\b)"
    },
    "types": {
      "name": "storage.type.gpscript",
      "match": "(?i:\\b(Boolean|Double|Integer|Int|String|ADSR|AfterTouchMessage|AutoSustainer|Block|ChordRecognizer|Continuous|ControlChangeMessage|CurveComponent|Discrete|ExternalApplication|ExternalWidget|Generator|MidiInBlock|MidiInDeviceAlias|MidiMessage|MidiOutBlock|MidiSequence|MultiChannelNoteTracker|NoteMapper|NoteMessage|NoteTracker|OSCMessage|Parameter|PitchBendMessage|PolyTouchMessage|ProgramChangeMessage|Subrange|SysexManager|SysexMessage|ThresholdDetector|Widget)\\b)"
    },
    "callbacks": {
      "name": "support.function.callback.gpscript",
      "match": "(?i:\\b(Activate|Deactivate|Variation|NoteOnEvent|NoteOffEvent|NoteEvent|ControlChangeEvent|PitchBendEvent|AftertouchEvent|PolytouchEvent|ProgramChangeEvent|MidiEvent|SysexEvent|WidgetValueChanged|ParameterValueChanged|TimePassing|OSCMessageReceived|BeatChanged|SystemEvent|Rackspace|Song|Songpart|Keystroke|TimerTick)\\b)"
    },
    "keywords": {
      "name": "keyword.control.gpscript",
      "match": "(?i:\\b(Var|Function|Returns|If|Then|Else|End|For|While|Do|On|From|Matching|Initialization|Array|AsNoteNames|Select|Case|Break|Continue|And|Or|Not)\\b)"
    },
    "function-declaration": {
      "match": "(?i:\\b(Function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b)",
      "captures": {
        "1": {
          "name": "keyword.control.gpscript"
        },
        "2": {
          "name": "entity.name.function.gpscript"
        }
      }
    },
    "function-call": {
      "name": "support.function.gpscript",
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
    },
    "operators": {
      "name": "keyword.operator.gpscript",
      "match": "<--|\\.\\.|<=|>=|==|!=|[+\\-*/%<>#=]"
    }
  }
}
