{
  "editor.semanticHighlighting.enabled": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "comment.line.double-slash.gpscript, comment.block.gpscript",
        "settings": {
          "foreground": "#6A9955",
          "fontStyle": "italic"
        }
      },
      {
        "scope": "keyword.control.gpscript",
        "settings": {
          "foreground": "#C586C0",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "keyword.operator.gpscript",
        "settings": {
          "foreground": "#D4D4D4"
        }
      },
      {
        "scope": "storage.type.gpscript",
        "settings": {
          "foreground": "#4EC9B0"
        }
      },
      {
        "scope": "entity.name.function.gpscript",
        "settings": {
          "foreground": "#DCDCAA",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "support.function.gpscript, support.function.callback.gpscript",
        "settings": {
          "foreground": "#DCDCAA"
        }
      },
      {
        "scope": "constant.numeric.float.gpscript, constant.numeric.integer.gpscript, constant.numeric.note.gpscript",
        "settings": {
          "foreground": "#B5CEA8"
        }
      },
      {
        "scope": "constant.language.boolean.gpscript",
        "settings": {
          "foreground": "#569CD6",
          "fontStyle": "bold"
        }
      },
      {
        "scope": "string.quoted.double.gpscript, string.unquoted.heredoc.gpscript",
        "settings": {
          "foreground": "#CE9178"
        }
      },
      {
        "scope": "constant.other.sysex.gpscript",
        "settings": {
          "foreground": "#9CDCFE"
        }
      }
    ]
  }
}
